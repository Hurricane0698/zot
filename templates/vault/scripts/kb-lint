#!/usr/bin/env python3
import json
import re
from collections import Counter, defaultdict
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
KB = REPO / "kb"
WIKI = KB / "wiki"
META = KB / "meta"
FEEDBACK = KB / "human" / "feedback"

WIKILINK_RE = re.compile(r"\[\[([^\]|#]+)")
FRONTMATTER_RE = re.compile(r"^---\n(.*?)\n---\n?", re.S)
FENCED_CODE_RE = re.compile(r"```[\s\S]*?```", re.M)
FEEDBACK_REQUIRED_FIELDS = {"type", "title", "target", "severity", "status", "created"}
VALID_FEEDBACK_STATUSES = {"open", "resolved"}
VALID_FEEDBACK_SEVERITIES = {"info", "suggest", "warn", "error"}


def note_name(path: Path) -> str:
    return path.stem


def parse_scalar(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] == "'":
        return value[1:-1].replace("''", "'")
    if len(value) >= 2 and value[0] == value[-1] == '"':
        try:
            return json.loads(value)
        except json.JSONDecodeError:
            return value[1:-1].replace('\\"', '"').replace("\\\\", "\\")
    return value


def normalize_note_lookup_name(value: str) -> str:
    name = Path(value).name.strip()
    if name.lower().endswith(".md"):
        return name[:-3]
    return name


def extract_aliases(text: str) -> set[str]:
    match = FRONTMATTER_RE.match(text)
    if not match:
        return set()

    aliases: set[str] = set()
    lines = match.group(1).splitlines()
    i = 0
    while i < len(lines):
        line = lines[i]
        stripped = line.strip()
        if not stripped.startswith("aliases:"):
            i += 1
            continue

        value = stripped.partition(":")[2].strip()
        if value.startswith("[") and value.endswith("]"):
            items = [parse_scalar(item.strip()) for item in value[1:-1].split(",")]
            aliases.update(item for item in items if item)
            return aliases
        if value:
            aliases.add(parse_scalar(value))
            return aliases

        i += 1
        while i < len(lines):
            child = lines[i].strip()
            if not child.startswith("- "):
                break
            alias = parse_scalar(child[2:].strip())
            if alias:
                aliases.add(alias)
            i += 1
        return aliases

    return aliases


def parse_frontmatter(text: str) -> dict | None:
    match = FRONTMATTER_RE.match(text)
    if not match:
        return None

    result: dict = {}
    for line in match.group(1).splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or ":" not in line:
            continue
        key, _, rest = line.partition(":")
        value = rest.strip()
        if value.startswith("[") and value.endswith("]"):
            items = [parse_scalar(item.strip()) for item in value[1:-1].split(",")]
            result[key.strip()] = [item for item in items if item]
        else:
            result[key.strip()] = parse_scalar(value)
    return result


def normalize_target(target: str) -> str:
    cleaned = target.strip()
    if cleaned.startswith("[[") and cleaned.endswith("]]"):
        cleaned = cleaned[2:-2]
    cleaned = cleaned.split("|", 1)[0]
    cleaned = cleaned.split("#", 1)[0]
    cleaned = cleaned.strip()
    return normalize_note_lookup_name(cleaned) if cleaned else ""


def strip_fenced_code_blocks(text: str) -> str:
    return FENCED_CODE_RE.sub("", text)


def main() -> int:
    notes = sorted(WIKI.rglob("*.md"))
    if not notes:
        print("No wiki notes found.")
        return 0

    link_sources = notes + sorted(META.rglob("*.md")) + sorted(REPO.glob("*.md"))

    names = Counter(note_name(p) for p in notes)
    duplicates = sorted(name for name, count in names.items() if count > 1)
    inbound = Counter()
    missing_frontmatter = []
    missing_sources = []
    broken_links = defaultdict(set)
    alias_to_note = {}
    for path in KB.rglob("*.md"):
        text = path.read_text(encoding="utf-8")
        canonical = path.stem
        alias_to_note[canonical] = canonical
        for alias in extract_aliases(text):
            alias_to_note.setdefault(alias, canonical)

    for path in REPO.glob("*.md"):
        text = path.read_text(encoding="utf-8")
        canonical = path.stem
        alias_to_note[canonical] = canonical
        for alias in extract_aliases(text):
            alias_to_note.setdefault(alias, canonical)

    vault_note_names = set(alias_to_note)

    for note in link_sources:
        text = note.read_text(encoding="utf-8")
        rel = note.relative_to(REPO)
        rel_posix = str(rel).replace("\\", "/")

        if note in notes and not text.startswith("---\n"):
            missing_frontmatter.append(str(rel))
        if note in notes and "## Sources" not in text and "/maps/" not in rel_posix:
            missing_sources.append(str(rel))

        visible_text = strip_fenced_code_blocks(text)
        for raw_target in WIKILINK_RE.findall(visible_text):
            target = raw_target.strip()
            if not target:
                continue
            target_name = normalize_note_lookup_name(target)
            canonical_target = alias_to_note.get(target_name, target_name)
            if canonical_target in names:
                inbound[canonical_target] += 1
            elif target_name not in vault_note_names:
                broken_links[str(rel)].add(target_name)

    orphans = sorted(
        str(p.relative_to(REPO))
        for p in notes
        if inbound[note_name(p)] == 0 and "/maps/" not in str(p).replace("\\", "/")
    )

    feedback_shape_issues = []
    feedback_target_issues = []
    feedback_files = sorted(p for p in FEEDBACK.rglob("*.md") if p.name != ".gitkeep") if FEEDBACK.exists() else []
    for path in feedback_files:
        rel = str(path.relative_to(REPO))
        text = path.read_text(encoding="utf-8")
        frontmatter = parse_frontmatter(text)
        if frontmatter is None:
            feedback_shape_issues.append(f"{rel} - missing frontmatter")
            continue

        missing = sorted(FEEDBACK_REQUIRED_FIELDS - set(frontmatter))
        if missing:
            feedback_shape_issues.append(f"{rel} - missing fields: {', '.join(missing)}")
            continue

        if frontmatter.get("type") != "feedback":
            feedback_shape_issues.append(f"{rel} - type must be feedback")
        if frontmatter.get("severity") not in VALID_FEEDBACK_SEVERITIES:
            feedback_shape_issues.append(f"{rel} - invalid severity: {frontmatter.get('severity')}")

        expected_status = "resolved" if "resolved" in path.parts else "open"
        if frontmatter.get("status") not in VALID_FEEDBACK_STATUSES:
            feedback_shape_issues.append(f"{rel} - invalid status: {frontmatter.get('status')}")
        elif frontmatter.get("status") != expected_status:
            feedback_shape_issues.append(f"{rel} - status should be {expected_status}")

        target_name = normalize_target(str(frontmatter.get("target", "")))
        canonical_target = alias_to_note.get(target_name, target_name)
        if not target_name or canonical_target not in vault_note_names:
            feedback_target_issues.append(f"{rel} - missing target: {frontmatter.get('target')}")

    print(f"Total wiki notes: {len(notes)}")
    print(f"Duplicate note names: {len(duplicates)}")
    for item in duplicates:
        print(f"  DUPLICATE: {item}")

    print(f"Orphan wiki notes: {len(orphans)}")
    for item in orphans:
        print(f"  ORPHAN: {item}")

    print(f"Missing frontmatter: {len(missing_frontmatter)}")
    for item in missing_frontmatter:
        print(f"  NO FRONTMATTER: {item}")

    print(f"Missing ## Sources: {len(missing_sources)}")
    for item in missing_sources:
        print(f"  NO SOURCES: {item}")

    broken_count = sum(len(v) for v in broken_links.values())
    print(f"Potential broken wikilinks: {broken_count}")
    for note, targets in sorted(broken_links.items()):
        for target in sorted(targets):
            print(f"  BROKEN?: {note} -> {target}")

    print(f"Feedback shape issues: {len(feedback_shape_issues)}")
    for item in feedback_shape_issues:
        print(f"  FEEDBACK SHAPE: {item}")

    print(f"Feedback target issues: {len(feedback_target_issues)}")
    for item in feedback_target_issues:
        print(f"  FEEDBACK TARGET: {item}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

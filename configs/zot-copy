#!/usr/bin/env bash
set -euo pipefail

if [[ -x "$HOME/.local/bin/win-copy" ]]; then
  exec "$HOME/.local/bin/win-copy"
fi

if command -v clip.exe >/dev/null 2>&1; then
  exec clip.exe
fi

if command -v pbcopy >/dev/null 2>&1; then
  exec pbcopy
fi

if command -v wl-copy >/dev/null 2>&1; then
  exec wl-copy
fi

if command -v xclip >/dev/null 2>&1; then
  exec xclip -selection clipboard
fi

if command -v xsel >/dev/null 2>&1; then
  exec xsel --clipboard --input
fi

echo "zot-copy: no clipboard backend found (checked win-copy, clip.exe, pbcopy, wl-copy, xclip, xsel)." >&2
exit 1

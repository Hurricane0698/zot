#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: scripts/init-vault <vault-path> [--force]

Creates an Obsidian-compatible knowledge base scaffold.
Default behavior is non-destructive: existing files are not overwritten.
USAGE
}

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

vault_path="$1"
shift || true
force=false
for arg in "$@"; do
  case "$arg" in
    --force) force=true ;;
    --help|-h) usage; exit 0 ;;
    *) echo "Unknown option: $arg" >&2; exit 1 ;;
  esac
done

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
template_dir="$repo_root/templates/vault"

[[ -d "$template_dir" ]] || { echo "Missing template dir: $template_dir" >&2; exit 1; }

mkdir -p "$vault_path"
vault_path="$(cd "$vault_path" && pwd -P)"
vault_kb_path="$vault_path/kb"
tooling_env="$vault_kb_path/meta/tooling.env"

copy_missing() {
  local src="$1"
  local dst="$2"
  (
    cd "$src"
    while IFS= read -r -d '' dir; do
      mkdir -p "$dst/$dir"
    done < <(find . -type d -print0)
    while IFS= read -r -d '' file; do
      if [[ ! -e "$dst/$file" ]]; then
        cp -p "$file" "$dst/$file"
      fi
    done < <(find . -type f -print0)
  )
}

normalize_dir() {
  local path="$1"
  [[ -n "$path" && -d "$path" ]] || return 1
  (cd "$path" && pwd -P)
}

read_tooling_collection() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  sed -n 's/^[[:space:]]*ZOT_QMD_COLLECTION=//p' "$file" | head -n1
}

generate_collection_name() {
  python3 - "$1" <<'PY'
from pathlib import Path
import hashlib
import re
import sys

path = str(Path(sys.argv[1]).resolve())
slug = re.sub(r'[^a-z0-9]+', '_', Path(path).name.lower()).strip('_') or 'vault'
digest = hashlib.sha1(path.encode('utf-8')).hexdigest()[:10]
print(f"zot_kb_{slug}_{digest}")
PY
}

write_tooling_env() {
  local file="$1"
  local collection="$2"
  mkdir -p "$(dirname "$file")"
  {
    echo "# Generated by zot."
    echo "# Keeps this vault bound to a stable, vault-local QMD collection."
    printf 'ZOT_QMD_COLLECTION=%s\n' "$collection"
  } > "$file"
}

qmd_collection_path() {
  local collection="$1"
  qmd collection show "$collection" 2>/dev/null | sed -n 's/^[[:space:]]*Path:[[:space:]]*//p' | head -n1
}

validate_collection_name() {
  local collection="$1"
  [[ "$collection" =~ ^[A-Za-z0-9._-]+$ ]]
}

if $force; then
  cp -R "$template_dir"/. "$vault_path"/
else
  copy_missing "$template_dir" "$vault_path"
fi

find "$vault_path/scripts" -type f -exec chmod +x {} + 2>/dev/null || true

explicit_collection="${ZOT_QMD_COLLECTION:-${QMD_COLLECTION:-}}"
stored_collection="$(read_tooling_collection "$tooling_env" || true)"
generated_collection="$(generate_collection_name "$vault_path")"
collection="${explicit_collection:-${stored_collection:-$generated_collection}}"

if ! validate_collection_name "$collection"; then
  echo "[ERROR] Invalid QMD collection name: '$collection'" >&2
  echo "        Use only letters, numbers, dot, underscore, or hyphen." >&2
  exit 1
fi

if command -v qmd >/dev/null 2>&1; then
  existing_path=""
  if qmd collection show "$collection" >/dev/null 2>&1; then
    existing_path="$(qmd_collection_path "$collection")"
    if normalized_existing="$(normalize_dir "$existing_path" 2>/dev/null)"; then
      existing_path="$normalized_existing"
    fi
    if [[ "$existing_path" != "$vault_kb_path" ]]; then
      if [[ -n "$explicit_collection" ]]; then
        echo "[ERROR] QMD collection '$collection' already points to '$existing_path', not '$vault_kb_path'." >&2
        echo "        Set a different QMD_COLLECTION or remove/rename the existing collection first." >&2
        exit 1
      fi
      if [[ "$collection" != "$generated_collection" ]]; then
        echo "[WARN] Stored qmd collection '$collection' points to '$existing_path'."
        echo "[INFO] Switching this vault to '$generated_collection' instead."
        collection="$generated_collection"
      else
        echo "[ERROR] Generated qmd collection '$collection' is already bound to '$existing_path'." >&2
        echo "        Remove/rename that collection or re-run with QMD_COLLECTION=<new-name>." >&2
        exit 1
      fi
    fi
  fi

  if qmd collection show "$collection" >/dev/null 2>&1; then
    final_path="$(qmd_collection_path "$collection")"
    if normalized_final_path="$(normalize_dir "$final_path" 2>/dev/null)"; then
      final_path="$normalized_final_path"
    fi
    if [[ "$final_path" != "$vault_kb_path" ]]; then
      echo "[ERROR] QMD collection '$collection' still points to '$final_path', not '$vault_kb_path'." >&2
      echo "        Remove/rename that collection or re-run with QMD_COLLECTION=<new-name>." >&2
      exit 1
    fi
    echo "[OK] qmd collection ready: $collection -> $vault_kb_path"
  else
    echo "[INFO] Creating qmd collection '$collection' for $vault_kb_path"
    if qmd collection add "$vault_kb_path" --name "$collection"; then
      echo "[OK] qmd collection created: $collection"
    else
      echo "[WARN] Failed to create qmd collection '$collection'. You can retry manually later." >&2
    fi
  fi
else
  echo "[WARN] qmd not found. Run ./setup.sh first, or use scripts/kb-search with ripgrep fallback."
fi

write_tooling_env "$tooling_env" "$collection"

cat <<EOF2
[OK] Vault scaffold ready: $vault_path

Open in Obsidian:
  open -a Obsidian "$vault_path"

Search:
  export ZOT_VAULT="$vault_path"
  "$vault_path/scripts/kb-search" "your query"
  "$vault_path/scripts/kb-capture" --kind conversation --title "Terminal finding" --stdin
  "$vault_path/scripts/kb-log" ingest "title" --raw "[[raw-note]]" --changed "[[wiki-note]]" --output "[[drill-note]]" --note "why it matters"
  "$vault_path/scripts/kb-lint"
  "$vault_path/scripts/kb-smoke-test"

QMD collection:
  $collection

Tip:
  Bundled home-level skills like zot-vault-search / zot-vault-ingest / zot-vault-review
  can operate directly on this vault.
EOF2
